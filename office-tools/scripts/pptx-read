#!/usr/bin/env python3
"""
读取PowerPoint文档(.pptx)并提取文本内容
"""

import sys
import os

# 添加虚拟环境路径到Python路径
venv_path = os.path.join(os.path.dirname(os.path.dirname(__file__)), '.venv')
site_packages = os.path.join(venv_path, 'lib', 'python3.12', 'site-packages')
sys.path.insert(0, site_packages)

from pptx import Presentation


def read_pptx(file_path):
    """读取PowerPoint文档并返回所有文本"""
    prs = Presentation(file_path)
    output = []

    for i, slide in enumerate(prs.slides, 1):
        output.append(f"--- 幻灯片 {i} ---")

        # 提取幻灯片中的所有文本
        for shape in slide.shapes:
            if hasattr(shape, "text") and shape.text.strip():
                output.append(shape.text)

            # 处理表格
            if shape.has_table:
                table = shape.table
                for row in table.rows:
                    row_text = []
                    for cell in row.cells:
                        if cell.text.strip():
                            row_text.append(cell.text.strip())
                    if row_text:
                        output.append(' | '.join(row_text))

        output.append("")  # 幻灯片之间空一行

    return '\n'.join(output)


if __name__ == '__main__':
    if len(sys.argv) < 2:
        print("用法: pptx-read <文件路径>", file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]
    if not os.path.exists(file_path):
        print(f"错误: 文件不存在 - {file_path}", file=sys.stderr)
        sys.exit(1)

    try:
        text = read_pptx(file_path)
        print(text)
    except Exception as e:
        print(f"错误: {e}", file=sys.stderr)
        sys.exit(1)
