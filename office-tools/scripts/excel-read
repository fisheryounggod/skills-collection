#!/usr/bin/env python3
"""
读取Excel文档(.xlsx)并提取表格内容
"""

import sys
import os

# 添加虚拟环境路径到Python路径
venv_path = os.path.join(os.path.dirname(os.path.dirname(__file__)), '.venv')
site_packages = os.path.join(venv_path, 'lib', 'python3.12', 'site-packages')
sys.path.insert(0, site_packages)

from openpyxl import load_workbook


def read_excel(file_path, sheet_name=None):
    """读取Excel文档并返回表格内容"""
    wb = load_workbook(file_path, read_only=True)

    if sheet_name:
        if sheet_name not in wb.sheetnames:
            print(f"错误: 工作表 '{sheet_name}' 不存在", file=sys.stderr)
            print(f"可用工作表: {', '.join(wb.sheetnames)}", file=sys.stderr)
            sys.exit(1)
        sheets = [wb[sheet_name]]
    else:
        # 读取第一个工作表
        sheets = [wb.active]

    output = []

    for sheet in sheets:
        output.append(f"工作表: {sheet.title}")
        output.append("-" * 40)

        for row in sheet.iter_rows(values_only=True):
            # 转换None为空字符串
            row_text = [str(cell) if cell is not None else '' for cell in row]
            # 过滤空行
            if any(cell.strip() for cell in row_text):
                output.append('\t'.join(row_text))

        output.append("")  # 工作表之间空一行

    return '\n'.join(output)


if __name__ == '__main__':
    if len(sys.argv) < 2:
        print("用法: excel-read <文件路径> [工作表名称]", file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]
    sheet_name = sys.argv[2] if len(sys.argv) > 2 else None

    if not os.path.exists(file_path):
        print(f"错误: 文件不存在 - {file_path}", file=sys.stderr)
        sys.exit(1)

    try:
        text = read_excel(file_path, sheet_name)
        print(text)
    except Exception as e:
        print(f"错误: {e}", file=sys.stderr)
        sys.exit(1)
